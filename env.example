# Token du bot Discord (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# ID du salon Discord où le message doit être affiché/édité
CHANNEL_ID=

# URL de base de l'API REST Palworld (attention au port, souvent le port RCON + quelques unités, ex: 8212)
# Format: http://IP_DU_SERVEUR:PORT/v1/api
PALWORLD_API_URL=http://127.0.0.1:8212/v1/api

# Mot de passe admin du serveur Palworld (AdminPassword dans PalWorldSettings.ini)
PALWORLD_ADMIN_PASSWORD=

# Intervalle de rafraichissement en secondes
REFRESH_SECONDS=60
